{
  "name": "iwa-ssh",
  "version": "0.1.89",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:chrome": "node scripts/dev-chrome.mjs",
    "install:iwa": "node scripts/install-iwa-dev.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run && node scripts/test-ssh-command-parser.mjs && node --experimental-strip-types scripts/test-restty-glyph-rendering.mjs && node scripts/test-wassh-terminal-size-patch.mjs",
    "typecheck": "tsc -b --noEmit",
    "generate:et-proto": "protoc -I app/src/et/proto --plugin=protoc-gen-es=./node_modules/.bin/protoc-gen-es --es_out=app/src/et/proto --es_opt=target=ts app/src/et/proto/ET.proto app/src/et/proto/ETerminal.proto",
    "fetch:et-protocol": "node scripts/fetch-et-protocol.mjs",
    "fetch-assets": "node scripts/fetch-upstream-assets.mjs",
    "bump-version": "node scripts/bump-version.mjs",
    "bundle:iwa": "node --experimental-strip-types iwa/build-bundle.mjs",
    "bundle:iwa:unsigned": "node --experimental-strip-types iwa/build-bundle.mjs --unsigned-only",
    "bundle:iwa:info": "node --experimental-strip-types iwa/bundle-info.mjs",
    "smoke:e2e": "node scripts/smoke-terminal.mjs",
    "smoke:ssh": "node scripts/smoke-ssh-interactive.mjs",
    "smoke:echo": "node scripts/smoke-echo.mjs",
    "check:regression": "node --experimental-strip-types scripts/check-storage-regression.mjs",
    "iwa:keygen": "bash scripts/generate-iwa-signing-key.sh",
    "iwa:update-id": "node --experimental-strip-types scripts/update-webbundle-id.mjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@eslzzyl/restty": "file:vendor/restty",
    "idb": "^8.0.3",
    "libsodium-wrappers": "^0.8.4"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@types/node": "^22.15.21",
    "fake-indexeddb": "^6.2.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
