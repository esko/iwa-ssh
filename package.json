{
  "name": "iwa-ssh",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:chrome": "node scripts/dev-chrome.mjs",
    "install:iwa": "node scripts/install-iwa-dev.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "fetch-assets": "node scripts/fetch-upstream-assets.mjs",
    "bundle:iwa": "node --experimental-strip-types iwa/build-bundle.mjs"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.3.0-beta.287",
    "@xterm/addon-fit": "^0.12.0-beta.287",
    "@xterm/addon-search": "^0.17.0-beta.287",
    "@xterm/addon-web-links": "^0.13.0-beta.287",
    "@xterm/xterm": "^6.1.0-beta.287",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
