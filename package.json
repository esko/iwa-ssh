{
  "name": "iwa-ssh",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:chrome": "node scripts/dev-chrome.mjs",
    "install:iwa": "node scripts/install-iwa-dev.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run && node scripts/test-ssh-command-parser.mjs",
    "typecheck": "tsc -b --noEmit",
    "fetch-assets": "node scripts/fetch-upstream-assets.mjs",
    "patch-ghostty-web": "node scripts/patch-ghostty-web.mjs",
    "postinstall": "node scripts/patch-ghostty-web.mjs",
    "bump-version": "node scripts/bump-version.mjs",
    "bundle:iwa": "node --experimental-strip-types iwa/build-bundle.mjs",
    "bundle:iwa:unsigned": "node --experimental-strip-types iwa/build-bundle.mjs --unsigned-only",
    "bundle:iwa:info": "node --experimental-strip-types iwa/bundle-info.mjs",
    "smoke:e2e": "node scripts/smoke-terminal.mjs",
    "smoke:ssh": "node scripts/smoke-ssh-interactive.mjs",
    "smoke:echo": "node scripts/smoke-echo.mjs",
    "check:regression": "node --experimental-strip-types scripts/check-storage-regression.mjs",
    "iwa:keygen": "bash scripts/generate-iwa-signing-key.sh",
    "iwa:update-id": "node --experimental-strip-types scripts/update-webbundle-id.mjs"
  },
  "dependencies": {
    "ghostty-web": "github:rcarmo/ghostty-web#b6b243d7f380f8307e375719968f6046f1102c48",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
